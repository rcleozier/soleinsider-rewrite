generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Article {
  id        Int       @id @default(autoincrement())
  title     String?   @db.VarChar(255)
  content   String?   @db.Text
  cover     String?   @db.VarChar(255)
  slug      String?   @db.VarChar(255)
  keywords  String?   @db.VarChar(255)
  createdAt DateTime? @map("created_at") @db.Timestamp(0)
  updatedAt DateTime? @map("updated_at") @db.Timestamp(0)

  @@map("articles")
}

model Product {
  id                  Int      @id @default(autoincrement())
  name                String   @db.VarChar(200)
  sku                 String   @db.VarChar(11)
  image               String   @db.Text
  link                String   @db.Text
  colorway            String   @db.VarChar(80)
  description         String   @db.Text
  content             String?  @db.Text
  slug                String   @db.VarChar(255)
  price               Decimal  @db.Decimal(5, 2)
  comingSoon          Int      @map("coming_soon")
  views               Int      @default(0)
  resale              String   @default("medium") @db.VarChar(50)
  type                String   @default("sneakers") @db.VarChar(40)
  stockxUrl           String   @map("stockx_url") @db.VarChar(90)
  stockxThumbnailUrl  String   @map("stockx_thumbnail_url") @db.Text
  stockxTickerSymbol  String   @map("stockx_ticker_symbol") @db.VarChar(90)
  stockxName          String   @map("stockx_name") @db.VarChar(90)
  stockxMake          String   @map("stockx_make") @db.VarChar(90)
  stockxModel         String   @map("stockx_model") @db.VarChar(90)
  stockxPrice         Int      @map("stockx_price")
  stockxHighestBid    Int      @map("stockx_highest_bid")
  stockxTotalDollars  Int      @map("stockx_total_dollars")
  stockxLowestAsk     Int      @map("stockx_lowest_ask")
  stockxLastSale      Int      @map("stockx_last_sale")
  stockxDeadstockSold Int      @map("stockx_deadstock_sold")
  stockxSalesLast72   Int      @map("stockx_sales_last_72")
  createdAt           DateTime @map("created_at") @db.Timestamp(0)
  updatedAt           DateTime @map("updated_at") @db.Timestamp(0)

  @@map("products")
}

model Comment {
  id        Int       @id @default(autoincrement())
  memberId  Int?      @map("member_id")
  productId Int?      @map("product_id")
  comment   String?   @db.Text
  votesUp   Int       @default(1) @map("votes_up")
  votesDown Int       @map("votes_down")
  createdAt DateTime? @map("created_at") @db.Timestamp(0)
  updatedAt DateTime? @map("updated_at") @db.Timestamp(0)

  @@index([productId], map: "comments_product_id_idx")
  @@map("comments")
}

model TempProductImage {
  id        Int     @id @default(autoincrement())
  productId Int?    @map("product_id")
  image     String? @db.Text

  @@map("temp_product_images")
}

model TempProduct {
  id          Int       @id @default(autoincrement())
  name        String    @db.VarChar(200)
  sku         String    @db.VarChar(11)
  image       String    @db.Text
  link        String    @db.Text
  description String    @db.Text
  content     String?   @db.Text
  slug        String    @db.VarChar(255)
  hash        String?   @db.VarChar(255)
  price       Decimal   @db.Decimal(5, 2)
  status      String?   @default("new") @db.VarChar(11)
  type        String    @db.VarChar(30)
  releaseDate DateTime? @map("release_date") @db.Timestamp(0)
  createdAt   DateTime  @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime  @map("updated_at") @db.Timestamp(0)

  @@map("temp_products")
}

model ReleaseInterest {
  id        Int       @id @default(autoincrement())
  memberId  Int?      @map("member_id")
  productId Int?      @map("product_id")
  status    Int?
  createdAt DateTime? @map("created_at") @db.Timestamp(0)

  @@map("release_interest")
}

model ReleaseDateUpdateLog {
  id        Int       @id @default(autoincrement())
  productId Int?      @map("product_id")
  oldDate   DateTime? @map("old_date") @db.Timestamp(0)
  newDate   DateTime? @map("new_date") @db.Timestamp(0)
  createdAt DateTime? @map("created_at") @db.Timestamp(0)
  updatedAt DateTime? @map("updated_at") @db.Timestamp(0)

  @@map("release_date_update_log")
}

model Release {
  id          Int      @id @default(autoincrement())
  productId   Int      @map("product_id")
  releaseDate DateTime @map("release_date") @db.Timestamp(0)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime @map("updated_at") @db.Timestamp(0)

  @@index([productId], map: "releases_product_id_idx")
  @@map("releases")
}

model ProductImage {
  id        Int     @id @default(autoincrement())
  productId Int     @map("product_id")
  optimized Boolean @default(false)
  image     String  @db.Text

  @@map("product_images")
}

model ProductCheck {
  id            Int      @id @default(autoincrement())
  productId     Int      @map("product_id")
  link          String   @db.Text
  searchString  String   @map("search_string") @db.Text
  falseNegative String   @map("false_negative") @db.Text
  status        Int      @default(1)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt     DateTime @map("updated_at") @db.Timestamp(0)

  @@map("product_checks")
}

model Member {
  id           Int      @id @default(autoincrement())
  email        String   @unique(map: "members_email_key") @db.VarChar(80)
  name         String?  @db.VarChar(120)
  password     String   @db.VarChar(80)
  phoneNumber  String   @map("phone_number") @db.VarChar(80)
  carrier      Int
  memberType   String?  @map("member_type") @db.VarChar(40)
  verified     Bytes    @db.ByteA
  profileImage String   @default("default.png") @map("profile_image") @db.VarChar(255)
  bouncedEmail Int      @map("bounced_email")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt    DateTime @map("updated_at") @db.Timestamp(0)

  @@index([email], map: "members_email_idx")
  @@map("members")
}

/// A member's saved sneakers — distinct from a cop/drop vote (ReleaseInterest),
/// which is an opinion on the release, not a bookmark.
model Favorite {
  id        Int      @id @default(autoincrement())
  memberId  Int      @map("member_id")
  productId Int      @map("product_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  @@unique([memberId, productId], map: "favorites_member_product_key")
  @@index([memberId], map: "favorites_member_id_idx")
  @@map("favorites")
}

model MemberLogin {
  id        Int       @id @default(autoincrement())
  memberId  Int?      @map("member_id")
  timestamp DateTime? @db.Timestamp(0)

  @@map("member_logins")
}

/// One-time code minted after a successful web login, exchanged by the
/// mobile app for a long-lived bearer token. Never stores the raw code —
/// only its SHA-256 hash — and expires in minutes, not days.
model MobileAuthCode {
  id        Int       @id @default(autoincrement())
  codeHash  String    @unique @map("code_hash") @db.VarChar(64)
  memberId  Int       @map("member_id")
  expiresAt DateTime  @map("expires_at") @db.Timestamp(0)
  usedAt    DateTime? @map("used_at") @db.Timestamp(0)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(0)

  @@index([memberId], map: "mobile_auth_codes_member_id_idx")
  @@map("mobile_auth_codes")
}

/// Long-lived mobile bearer token, separate from the web session. Only the
/// SHA-256 hash is stored; the raw token is shown to the app exactly once,
/// at exchange time.
model MobileSession {
  id         Int       @id @default(autoincrement())
  tokenHash  String    @unique @map("token_hash") @db.VarChar(64)
  memberId   Int       @map("member_id")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  lastUsedAt DateTime? @map("last_used_at") @db.Timestamp(0)
  revokedAt  DateTime? @map("revoked_at") @db.Timestamp(0)
  expiresAt  DateTime  @map("expires_at") @db.Timestamp(0)

  @@index([memberId], map: "mobile_sessions_member_id_idx")
  @@map("mobile_sessions")
}
