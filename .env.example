DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require&channel_binding=require"
CRON_SECRET=""
CRAWLER_INGEST_SECRET=""
SOLEINSIDER_INGEST_URL="http://localhost:3000/public/ingest/saveRelease"

# Product image uploads (admin "Add Release" form) — see src/lib/s3.ts
AWS_REGION=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_BUCKET_NAME=""
# Optional: a CloudFront/custom domain in front of the bucket. If unset,
# uploads resolve to the bucket's own S3 endpoint.
S3_PUBLIC_HOSTNAME=""

# Article generation — see src/lib/openaiClient.ts
# Run with: npm run articles:generate -- --count=3 [--category=sports]
# Or via cron: GET /api/cron/generateArticles?count=2
OPENAI_API_KEY=""
# Optional overrides. Defaults are the cheap options.
OPENAI_TEXT_MODEL=""      # default "gpt-4o-mini"
OPENAI_IMAGE_MODEL=""     # default "gpt-image-1"
OPENAI_IMAGE_SIZE=""      # default "1024x1024"
OPENAI_IMAGE_QUALITY=""   # default "low" (gpt-image-1 only)
